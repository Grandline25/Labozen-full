body.pbm-addons-header-template.wp-singular.pbmit-header-footer-template-default.single.single-pbmit-header-footer #secondary {
	display: none;
}
body.pbm-addons-header-template.wp-singular.pbmit-header-footer-template-default.single.single-pbmit-header-footer #primary {
	flex: 0 0 100%;
	max-width: 100%;
}
body.pbm-addons-header-template.wp-singular.pbmit-header-footer-template-default.single.single-pbmit-header-footer #content {
